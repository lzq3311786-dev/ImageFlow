{
  "name": "img-studio",
  "version": "2.1.3",
  "description": "ImageFlow - 图片压缩、智能归类、智能切片与智能模板",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 >nul && electron .",
    "build": "electron-builder",
    "release:github": "electron-builder --publish always"
  },
  "keywords": [
    "image",
    "compress",
    "organize"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/lzq3311786-dev/ImageFlow.git"
  },
  "build": {
    "appId": "com.imageWorkbench.app",
    "productName": "ImageFlow",
    "publish": [
      {
        "provider": "github",
        "owner": "lzq3311786-dev",
        "repo": "ImageFlow",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "*.html",
      "*.png",
      "*.ico",
      "node_modules/**/*"
    ],
    "extraFiles": [
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "template_renderer.py",
        "to": "template_renderer.py"
      },
      {
        "from": "template_mask_points.py",
        "to": "template_mask_points.py"
      },
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "watermarks",
        "to": "watermarks",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  }
}
